---
import PrimaryBtn from "../components/primary-button.astro";
import Portfolio from "../components/portfolio.astro";
import Footer from "../components/footer.astro";
---

<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
      integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA=="
      crossorigin="anonymous"
      referrerpolicy="no-referrer"
    />
    <link rel="stylesheet" href="/fonts.css" />
    <title>Home - Marcus Leonas Harvey</title>
  </head>
  <body class="bg-black">
    <section
      class="flex flex-col w-full rounded-b-[50px] h-[90vh] overflow-hidden justify-between p-12 bg-[#eeeee9]"
    >
      <div class="flex flex-col">
        <h1 class="text-4xl font-hubot md:text-6xl lg:text-8xl font-bold">
          I'm a Frontend Web Developer & Novice Theatre Technician.
        </h1>
      </div>
      <div class="flex flex-row justify-between">
        <a
          href="#about"
          class="max-md:hidden transform flex w-max duration-1000 hover:scale-110 hover:text-primary"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="1.5"
            stroke="currentColor"
            class="w-16 h-16"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M19.5 13.5 12 21m0 0-7.5-7.5M12 21V3"></path>
          </svg>
        </a>
        <div class="flex flex-col max-md:w-full md:flex-row gap-2">
          <PrimaryBtn href="/blog">Blog</PrimaryBtn>
          <PrimaryBtn href="https://www.instagram.com/marcusleonas_public/">
            <i class="fa-brands fa-instagram"></i>
          </PrimaryBtn>
          <PrimaryBtn href="https://www.linkedin.com/in/marcusleonas/">
            <i class="fa-brands fa-linkedin-in"></i>
          </PrimaryBtn>
        </div>
      </div>
    </section>
    <section
      class="flex flex-col w-full rounded-[50px] overflow-hidden p-12 bg-primary"
      id="about"
    >
      <div class="flex flex-col gap-4 max-w-screen-2xl text-white mb-8">
        <h2 class="text-4xl md:text-6xl font-medium font-hubot">
          Hello, I'm Marcus. A 14-year-old Web Developer & Novice Theatre
          Technician.
        </h2>
        <p class="text-xl">
          Over the last 3 years, I have been fortunate enough to get many
          opportunities at theatres in my area. I've worked on 5+ shows as a
          technician, and more as various other roles.
        </p>
      </div>
      <div class="grid grid-cols-1 gap-2 items-center md:grid-cols-3">
        <img
          src="/img/featured_1.jpg"
          alt="Featured photo 1"
          class="rounded-2xl object-cover overflow-hidden h-full w-full"
        />
        <img
          src="/img/featured_2.jpg"
          alt="Featured photo 2"
          class="rounded-2xl object-cover overflow-hidden h-full w-full"
        />
        <img
          src="/img/featured_3.png"
          alt="Featured photo 3"
          class="rounded-2xl object-cover overflow-hidden h-full w-full"
        />
      </div>
    </section>
    <section
      class="flex flex-col w-full rounded-[50px] overflow-hidden p-12 bg-white"
    >
      <div class="mb-4 flex flex-col gap-2">
        <h2 class="text-4xl md:text-6xl font-medium font-hubot">Portfolio</h2>
        <p>
          For more info, please look at my <a
            href="https://www.linkedin.com/in/marcusleonas/" class="text-primary hover:underline">Linkedin</a
          >.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-2">
        <Portfolio />
      </div>
    </section>
    <Footer />
  </body>
</html>
